{
  "schemaVersion": 1,
  "id": "axion",
  "version": "${version}",
  "name": "Axion",
  "description": "Original in-world building workflows for Minecraft.",
  "authors": [
    "Towkio"
  ],
  "license": "All Rights Reserved",
  "contact": {
    "homepage": "https://castled.codes",
    "issues": "https://github.com/castledking/Axion/issues",
    "sources": "https://github.com/castledking/Axion"
  },
  "icon": "assets/axion/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "axion.AxionMod"
    ],
    "client": [
      "axion.AxionClientMod"
    ],
    "server": [
      "${fabric_server_entrypoint}"
    ],
    "modmenu": [
      "axion.client.compat.AxionModMenuIntegration"
    ]
  },
  "mixins": [
    "axion.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "${minecraft_version_range}",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.13.9+kotlin.2.3.10"
  },
  "suggests": {
    "modmenu": "*"
  }
}
